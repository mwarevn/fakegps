<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:fitsSystemWindows="false">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Map Container -->
        <include
            android:id="@+id/map_container"
            layout="@layout/map_container"
            android:layout_height="match_parent"
            android:layout_width="match_parent"/>

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="wrap_content"
            android:layout_height="?attr/actionBarSize"
            android:layout_marginTop="32dp"
            android:background="@android:color/transparent"
            app:navigationIcon="@drawable/ic_baseline_menu_24"
            app:navigationIconTint="?attr/colorPrimary"/>

        <!-- Search Box -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/search_card"
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="88dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <LinearLayout
                    android:id="@+id/start_search_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="6dp"
                    android:visibility="gone">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_mylocation"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="10dp"
                        app:tint="?attr/colorSecondary" />
                    <EditText
                        android:id="@+id/start_search"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Điểm bắt đầu"
                        android:background="@android:color/transparent"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="6dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_search"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="10dp"
                        app:tint="?attr/colorPrimary" />
                    <EditText
                        android:id="@+id/destination_search"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Điểm đến"
                        android:background="@android:color/transparent"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/use_current_location_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="8dp"
                    android:visibility="gone"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_menu_mylocation"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="10dp"
                        app:tint="?attr/colorPrimary" />
                    <TextView
                        android:id="@+id/use_current_location_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Dùng vị trí hiện tại"
                        android:textSize="12sp"
                        android:textColor="?attr/colorPrimary" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/swap_button_container"
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/search_card"
            android:layout_alignStart="@id/search_card"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp">
            <ImageButton
                android:id="@+id/swap_locations_button"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_reverse"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"
                app:tint="?attr/colorPrimary" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Navigation Controls -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/navigation_controls_card"
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:id="@+id/nav_controls_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/distance_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary"/>
                    <TextView
                        android:id="@+id/speed_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>
                    <ImageButton
                        android:id="@+id/nav_controls_toggle"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_expand_less"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/nav_controls_expandable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/nav_from_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:alpha="0.7"/>
                    <TextView
                        android:id="@+id/nav_to_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:alpha="0.7"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/auto_curve_speed_checkbox"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Auto"
                            android:textSize="11sp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"/>
                        <com.google.android.material.slider.Slider
                            android:id="@+id/speed_slider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="0"
                            android:valueTo="400"
                            app:labelBehavior="gone"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/pause_button"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="Tạm dừng"
                            android:textSize="12sp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:icon="@drawable/ic_pause"
                            app:iconSize="16dp"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/resume_button"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="Tiếp tục"
                            android:textSize="12sp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:visibility="gone"
                            app:icon="@drawable/ic_play"
                            app:iconSize="16dp"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/stop_button"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="Dừng"
                            android:textSize="12sp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:textColor="?attr/colorError"
                            app:strokeColor="?attr/colorError"
                            app:iconTint="?attr/colorError"
                            app:icon="@drawable/ic_stop"
                            app:iconSize="16dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Completion Actions -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/completion_actions_card"
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/completed_restart_button"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Lại"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:icon="@drawable/ic_restart"
                    app:iconSize="16dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/completed_finish_button"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Xong"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:icon="@drawable/ic_check_circle"
                    app:iconSize="16dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Route Status Cards -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/route_loading_card"
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:visibility="gone"
            app:cardCornerRadius="16dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:gravity="center">
                <ProgressBar android:layout_width="20dp" android:layout_height="20dp" android:layout_marginEnd="10dp"/>
                <TextView android:id="@+id/route_loading_progress_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đang tìm..." android:textSize="13sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/route_error_card"
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_margin="12dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="?attr/colorErrorContainer">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView android:id="@+id/route_error_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="?attr/colorOnErrorContainer" android:textSize="12sp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="end" android:layout_marginTop="4dp">
                    <com.google.android.material.button.MaterialButton android:id="@+id/route_error_cancel_button" style="@style/Widget.Material3.Button.TextButton" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Hủy" android:textColor="?attr/colorOnErrorContainer" android:insetTop="0dp" android:insetBottom="0dp"/>
                    <com.google.android.material.button.MaterialButton android:id="@+id/route_retry_button" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Thử lại" android:insetTop="0dp" android:insetBottom="0dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Main Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">
            
            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_favorite_button"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:visibility="gone"
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_baseline_favorite"
                app:iconSize="18dp"
                android:text="Lưu"
                android:textSize="14sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cancel_route_button"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:visibility="gone"
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_clear_text"
                app:iconSize="18dp"
                android:text="Hủy"
                android:textSize="14sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textColor="?attr/colorError"
                app:iconTint="?attr/colorError"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/action_button"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:visibility="gone"
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_navigation"
                app:iconSize="20dp"
                android:text="Chỉ đường"
                android:textSize="14sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>
            
        </LinearLayout>

        <!-- Vertical FAB group -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="85dp"
            android:orientation="vertical"
            android:gravity="center">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/cameraFollowToggle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginBottom="4dp"
                android:visibility="gone"
                app:fabCustomSize="32dp"
                app:srcCompat="@drawable/ic_navigation"
                app:backgroundTint="?attr/colorSurface"
                app:elevation="2dp"
                app:maxImageSize="26dp"
                app:tint="?attr/colorOnSurface"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/replaceLocationButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginBottom="4dp"
                android:visibility="gone"
                app:fabCustomSize="32dp"
                app:srcCompat="@drawable/ic_reverse"
                app:backgroundTint="?attr/colorSurface"
                app:elevation="2dp"
                app:maxImageSize="26dp"
                app:tint="?attr/colorPrimary"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/getFakeLocation"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginBottom="4dp"
                android:visibility="gone"
                app:fabCustomSize="32dp"
                app:srcCompat="@drawable/ic_my_location"
                app:backgroundTint="?attr/colorSurface"
                app:elevation="2dp"
                app:maxImageSize="26dp"
                app:tint="#F44336"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/setLocationButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginBottom="4dp"
                app:fabCustomSize="32dp"
                app:srcCompat="@drawable/ic_location_on"
                app:backgroundTint="?attr/colorSurface"
                app:elevation="2dp"
                app:maxImageSize="26dp"
                app:tint="?attr/colorPrimary"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/getlocation"
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:fabCustomSize="32dp"
                app:srcCompat="@drawable/ic_my_location"
                app:backgroundTint="?attr/colorSurface"
                app:elevation="2dp"
                app:maxImageSize="26dp"
                app:tint="#2196F3"/>
        </LinearLayout>

    </RelativeLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/drawer_header"
        app:menu="@menu/main_menu" />

</androidx.drawerlayout.widget.DrawerLayout>